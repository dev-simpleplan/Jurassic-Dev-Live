{%- comment -%}
  Collection reviews carousel, scoped to the current collection's Okendo Group.
  Okendo's own carousel header is used as the section heading (styled to match the
  theme's headings). See snippets/collection-group-reviews.liquid for the group map.
{%- endcomment -%}
{%- liquid
  assign review_heading = section.settings.heading
  if review_heading == blank
    assign review_heading = 'sections.collection_reviews.heading' | t
  endif
-%}
<div class="collection-group-reviews section-{{ section.id }}-padding">
  {% render 'collection-group-reviews', header_text: review_heading %}
</div>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  /* Style Okendo's built-in carousel heading to match the theme's section headings. */
  .collection-group-reviews .oke-reviewCarousel-header {
    text-align: center;
  }
  .collection-group-reviews h2.oke-reviewCarousel-header-title {
    font-family: var(--scale)!important;
    margin-bottom: 25px!important;
    color: var(--pitch-black);
    text-align: center;
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Collection Reviews",
  "tag": "section",
  "class": "collection-group-reviews-section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Shows the Okendo reviews carousel scoped to this collection's group (see snippets/collection-group-reviews.liquid). The heading below is Okendo's own carousel header."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Leave blank to use the built-in translations (EN / DE / FR). Enter text here only to override for all languages."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ]
}
{% endschema %}
