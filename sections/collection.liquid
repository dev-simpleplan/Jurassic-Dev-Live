{% if collection.handle != 'all' %}
  {% comment %} <div class="collection-banner">
    <div class="container">
      <div class="cb-wrapper">
        <div class="heading center">
          <h1>{{ section.settings.head }}</h1>
        </div>
        <div class="cb-collection">
          {% for block in section.blocks %}
            {% assign collection_item = block.settings.col %}
            <a href="{{ collection_item.url }}" class="cbcIn">
              <div class="cbcImg">
                {% if collection_item.featured_image %}
                  <img src="{{ collection_item.featured_image | img_url: 'master' }}" alt="{{ collection_item.title }}">
                {% elsif block.settings.col_img %}
                  <img src="{{ block.settings.col_img | img_url: 'master' }}" alt="{{ collection_item.title }}">
                {% endif %}
              </div>

              <div class="cbcTxt">
                {% assign collection_title = block.settings.col_name %}
                {% if collection_title == '' %}
                  <p>{{ collection_item.title | strip_html | strip }}</p>
                {% else %}
                  <p>{{ block.settings.col_name }}</p>
                {% endif %}
              </div>
            </a>
          {% endfor %}
        </div>
      </div>
    </div>
  </div> {% endcomment %}
{% endif %}
<div class="collection-banner">
  <div class="collection-main">
    <div class="container">
      <div class="cb-wrapper">
        <div class="breadcrumbs">
            <a href="{{ routes.root_url }}">Home</a>
            <p>
              >
            </p>
            <p>
              {% if collection.handle == 'all' %}
                All {{ collection.title }}
              {% else %}
                {{ collection.metafields.custom.collection_short_name.value | default: collection.title }}
              {% endif %}
            </p>
          </div>
        {% comment %} <div class="heading">
          <h1>{{ section.settings.head }}</h1>
        </div> {% endcomment %}
        <div class="head">
          
          {% if collection.handle == 'all' %}
            <h1>All {{ collection.title }}</h1>
          {% else %}
            <h1>{{ collection.title }}</h1>
          {% endif %}
        </div> 
        {%- capture current_page_url -%}{{ content_for_header | split:'"pageurl":"' | last | split:'"' | first }}{%- endcapture -%}
        {%- liquid
          assign generic_collection_handles = "all,all-products,all-fruits,all-fruit,all-collections,shop-all,alle-produkte,alle-fruchte,alle-fruechte,tous-les-produits,tous-les-fruits" | split: ","
          assign all_fruits_collection_handles = "all,all-products,all-fruits,all-fruit,alle-produkte,alle-fruchte,alle-fruechte,tous-les-produits,tous-les-fruits" | split: ","
          assign is_generic_collection = false
          assign is_all_fruits_collection = false
          assign unavailable_only_active = false
          assign almost_sold_out_only_active = false
          assign available_only_active = false
          assign availability_filter_value = ''
          assign untreated_only_active = false
          assign region_filter_value = ''
          assign has_active_collection_filters = false
          assign total_products_count = collection.all_products_count | default: collection.products_count
          assign filtered_products_count = collection.products_count

          if generic_collection_handles contains collection.handle or collection.handle contains 'all-' or collection.handle contains 'alle-' or collection.handle contains 'tous-les-'
            assign is_generic_collection = true
          endif

          if all_fruits_collection_handles contains collection.handle
            assign is_all_fruits_collection = true
          endif

          # Availability dropdown (in the Filter popup): Available Now / Almost Sold Out /
          # Coming Soon. jf_unavailable=1 is kept for backward compatibility with old links and is
          # treated the same as jf_availability=coming_soon.
          if current_page_url contains 'jf_availability=coming_soon' or current_page_url contains 'jf_unavailable=1'
            assign availability_filter_value = 'coming_soon'
            assign unavailable_only_active = true
            assign has_active_collection_filters = true
          elsif current_page_url contains 'jf_availability=almost_sold_out'
            assign availability_filter_value = 'almost_sold_out'
            assign almost_sold_out_only_active = true
            assign has_active_collection_filters = true
          elsif current_page_url contains 'jf_availability=available'
            assign availability_filter_value = 'available'
            assign available_only_active = true
            assign has_active_collection_filters = true
          endif

          if current_page_url contains 'jf_quality_label=untreated'
            assign untreated_only_active = true
            assign has_active_collection_filters = true
          endif

          if current_page_url contains 'jf_region=asia'
            assign region_filter_value = 'asia'
            assign has_active_collection_filters = true
          elsif current_page_url contains 'jf_region=europe'
            assign region_filter_value = 'europe'
            assign has_active_collection_filters = true
          elsif current_page_url contains 'jf_region=america'
            assign region_filter_value = 'america'
            assign has_active_collection_filters = true
          elsif current_page_url contains 'jf_region=africa'
            assign region_filter_value = 'africa'
            assign has_active_collection_filters = true
          endif

          if current_tags != blank
            assign has_active_collection_filters = true
          endif

          for filter in collection.filters
            if filter.type == 'boolean'
              if filter.true_value.active or filter.false_value.active
                assign has_active_collection_filters = true
              endif
            elsif filter.type == 'price_range'
              if filter.min_value.value != blank or filter.max_value.value != blank
                assign has_active_collection_filters = true
              endif
            elsif filter.active_values.size > 0
              assign has_active_collection_filters = true
            endif
          endfor
        -%}

        {%- if section.blocks.size > 0 -%}
          {%- capture collection_tiles -%}
            {% for block in section.blocks %}
              {% assign collection_item = block.settings.col %}

              {% if collection_item == blank or collection_item.handle == collection.handle %}
                {% continue %}
              {% endif %}

              {%- liquid
                assign show_collection_tile = false

                if is_generic_collection
                  if block.settings.hide_on_generic_collections != true
                    assign show_collection_tile = true
                  endif
                else
                  for parent_collection in block.settings.parent_collections
                    if parent_collection.handle == collection.handle
                      assign show_collection_tile = true
                      break
                    endif
                  endfor
                endif
              -%}

              {% unless show_collection_tile %}
                {% continue %}
              {% endunless %}

              <a href="{{ collection_item.url }}" class="cbcIn">
                <div class="cbcImg">
                  {% if collection_item.featured_image %}
                    <img src="{{ collection_item.featured_image | img_url: 'master' }}" alt="{{ collection_item.title }}">
                  {% elsif block.settings.col_img %}
                    <img src="{{ block.settings.col_img | img_url: 'master' }}" alt="{{ collection_item.title }}">
                  {% endif %}
                </div>

                <div class="cbcTxt">
                  {% assign collection_title = block.settings.col_name %}
                  {% assign collection_fallback_title = collection_item.metafields.custom.collection_short_name.value | default: collection_item.title | strip_html | strip %}
                  {% if collection_title == blank %}
                    <p>{{ collection_fallback_title }}</p>
                  {% else %}
                    <p>{{ block.settings.col_name }}</p>
                  {% endif %}
                </div>
              </a>
            {% endfor %}
          {%- endcapture -%}

          {%- if collection_tiles != blank -%}
            <div class="cb-collection">
              {{ collection_tiles }}
            </div>
          {%- endif -%}
        {%- endif -%}
      </div>
      <div class="cm-wrapper">
        {% comment %} <div class="head">
          
          {% if collection.handle == 'all' %}
            <h1>All {{ collection.title }}</h1>
          {% else %}
            <h2>{{ collection.title }}</h2>
          {% endif %}
        </div> {% endcomment %}
        <div class="tc-filter-wrap">
          <div class="filter-wrap filter">
            <div class="filter-buttton">
              Filter {% render 'filter-icon' %}
            </div>
            <div class="filter-sidebar">
              <div class="filtersidebar-in" data-lenis-prevent>
                <div class="filter-cross-div">
                  <p><span>Filter</span> {% render 'filter-icon' %}</p>
                  <div class="filter-close-mob">{% render 'cross' %}</div>
                </div>
                <div class="filter-sidebar-form">
                  <form>
                    {%- assign bestseller_active = false -%}
                    {%- for tag in current_tags -%}
                      {%- assign tag_handle = tag | handleize -%}
                      {%- if tag == 'Best Seller' or tag_handle == 'best-seller' -%}
                        {%- assign bestseller_active = true -%}
                      {%- endif -%}
                    {%- endfor -%}

                    <div class="form-filter-wrap list">
                      <div class="ff-head">
                        <p>Sort By</p>
                        <div class="filter-down-arrow">{% render "icon-arrow_down" %}</div>
                      </div>
                      <div class="ff-in">
                        <ul>
                          {% assign sort_by = collection.sort_by | default: collection.default_sort_by %}
                          {% for option in collection.sort_options %}
                            <li>
                              <label for="sort-{{ forloop.index }}">
                                <input type="radio" name="sort_by" value="{{ option.value }}" id="sort-{{ forloop.index }}" {% if option.value == sort_by %}checked{% endif %}>
                                {{ option.name }}
                              </label>
                            </li>
                          {% endfor %}
                        </ul>
                      </div>
                    </div>

                    {%- for filter in collection.filters -%}
                      <div class="form-filter-wrap {{ filter.type }}">
                        <div class="ff-head">
                          <p>{{ filter.label }}</p>
                          <div class="filter-down-arrow">{% render "icon-arrow_down" %}</div>
                        </div>
                        <div class="ff-in">
                          {%- case filter.type -%}
                            {%- when 'boolean' -%}
                              <ul>
                                <li>
                                  <label for="Filter-{{ filter.param_name }}-true">
                                    <input type="radio" name="{{ filter.param_name }}" value="{{ filter.true_value.value }}" id="Filter-{{ filter.param_name }}-true" {% if filter.true_value.active %}checked{% endif %} {% if filter.true_value.count == 0 and filter.true_value.active == false %}disabled{% endif %}>
                                    {{ filter.true_value.label }}
                                  </label>
                                </li>
                                <li>
                                  <label for="Filter-{{ filter.param_name }}-false">
                                    <input type="radio" name="{{ filter.param_name }}" value="{{ filter.false_value.value }}" id="Filter-{{ filter.param_name }}-false" {% if filter.false_value.active %}checked{% endif %} {% if filter.false_value.count == 0 and filter.false_value.active == false %}disabled{% endif %}>
                                    {{ filter.false_value.label }}
                                  </label>
                                </li>
                              </ul>
                            {%- when 'list' -%}
                              <ul>
                                {%- for filter_value in filter.values -%}
                                  <li>
                                    <label for="Filter-{{ filter.param_name }}-{{ forloop.index }}">
                                      <input type="checkbox" name="{{ filter_value.param_name }}" value="{{ filter_value.value }}" id="Filter-{{ filter.param_name }}-{{ forloop.index }}" {% if filter_value.active %}checked{% endif %} {% if filter_value.count == 0 and filter_value.active == false %}disabled{% endif %}>
                                      {{ filter_value.label }} ({{ filter_value.count }})
                                    </label>
                                  </li>
                                {%- endfor -%}
                              </ul>
                            {%- when 'price_range' -%}
                              {%- endcase -%}
                        </div>
                      </div>
                    {%- endfor -%}
                    {%- if collection.all_tags contains 'Best Seller' or bestseller_active -%}
                      <div class="form-filter-wrap list">
                        <div class="ff-head">
                          <p>{{ 'quick_filters.bestseller' | t }}</p>
                          <div class="filter-down-arrow">{% render "icon-arrow_down" %}</div>
                        </div>
                        <div class="ff-in">
                          <ul>
                            <li>
                              <label for="Filter-constraint-bestseller">
                                <input type="checkbox" name="constraint" value="best-seller" id="Filter-constraint-bestseller" {% if bestseller_active %}checked{% endif %}>
                                {{ 'quick_filters.bestseller' | t }}
                              </label>
                            </li>
                          </ul>
                        </div>
                      </div>
                    {%- endif -%}
                    <div class="form-filter-wrap list">
                      <div class="ff-head">
                        <p>{{ 'quick_filters.availability' | t }}</p>
                        <div class="filter-down-arrow">{% render "icon-arrow_down" %}</div>
                      </div>
                      <div class="ff-in">
                        <ul>
                          <li>
                            <label for="Filter-availability-available">
                              <input type="radio" name="jf_availability" value="available" id="Filter-availability-available" {% if availability_filter_value == 'available' %}checked{% endif %}>
                              {{ 'quick_filters.available_now' | t }}
                            </label>
                          </li>
                          <li>
                            <label for="Filter-availability-almost">
                              <input type="radio" name="jf_availability" value="almost_sold_out" id="Filter-availability-almost" {% if availability_filter_value == 'almost_sold_out' %}checked{% endif %}>
                              {{ 'quick_filters.almost_sold_out' | t }}
                            </label>
                          </li>
                          <li>
                            <label for="Filter-availability-coming-soon">
                              <input type="radio" name="jf_availability" value="coming_soon" id="Filter-availability-coming-soon" {% if availability_filter_value == 'coming_soon' %}checked{% endif %}>
                              {{ 'quick_filters.coming_soon' | t }}
                            </label>
                          </li>
                        </ul>
                      </div>
                    </div>
                    <div class="clear-filter">
                      <a href="{{ collection.url }}" class="reset-btn">Reset</a>
                      <button type="submit" class="apply-filter-btn custom-btn black">Apply Filters</button>
                    </div>
                  </form>
                </div>
              </div>
            </div>
          </div>

          {% comment %} Self Populating Filters with condition {% endcomment %}
          {% comment %} <div class="quick-filters">
            <div class="qf-wrapper">
              {%- assign availability_filter = collection.filters | where: "param_name", "filter.v.availability" | first -%}
              {%- if availability_filter -%}
                {%- for filter_value in availability_filter.values -%}
                  {%- if filter_value.count > 0 or filter_value.active -%}
                    <button type="button" class="qf-pill {% if filter_value.active %}is-active{% endif %}" data-name="{{ filter_value.param_name }}" data-value="{{ filter_value.value }}">
                      {{ filter_value.label }} ({{ filter_value.count }})
                    </button>
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
              <button type="button" class="qf-pill clear-all-pill" style="display: none;">Clear All ✕</button>
            </div>
          </div> {% endcomment %}

          {% comment %} Manual Filter with condition {% endcomment %}
           <div class="quick-filters">
  <div class="qf-wrapper">
    {%- assign bestseller_active = false -%}
    {%- for tag in current_tags -%}
      {%- assign tag_handle = tag | handleize -%}
      {%- if tag == 'Best Seller' or tag_handle == 'best-seller' -%}
        {%- assign bestseller_active = true -%}
      {%- endif -%}
    {%- endfor -%}

    {%- assign certificate_filter = collection.filters | where: "param_name", "filter.p.m.custom.certificate" | first -%}

    {%- comment -%} Detect organic products on the page (used to show the Organic & untreated pill). {%- endcomment -%}
    {%- assign has_organic_value = false -%}
    {%- if certificate_filter -%}
      {%- for value in certificate_filter.values -%}
        {%- assign organic_handle = value.label | handleize -%}
        {%- if organic_handle == 'organic' or organic_handle == 'bio' or organic_handle == 'biologique' -%}
          {%- assign has_organic_value = true -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}

    {%- comment -%} 1. Bestseller (when the page has bestsellers) {%- endcomment -%}
    {%- if collection.all_tags contains 'Best Seller' or bestseller_active -%}
      <button type="button"
              class="qf-pill {% if bestseller_active %}is-active{% endif %}"
              data-name="constraint"
              data-value="best-seller">
        {% if is_all_fruits_collection %}{{ 'quick_filters.bestsellers' | t }}{% else %}{{ 'quick_filters.bestseller' | t }}{% endif %}
      </button>
    {%- endif -%}

    {%- comment -%} 2. Organic & untreated (when organic products are present) {%- endcomment -%}
    {%- if has_organic_value -%}
      <button type="button"
              class="qf-pill {% if untreated_only_active %}is-active{% endif %}"
              data-name="jf_quality_label"
              data-value="untreated">
        {{ 'quick_filters.organic_untreated' | t }}
      </button>
    {%- endif -%}

    {%- comment -%} 3. Regions — only on the Fruits collection and the All products / all-fruits collections {%- endcomment -%}
    {%- assign fruit_collection_handles = "fruit,fruits,fruits-en-saison,obst,fruechte,fruchte" | split: "," -%}
    {%- assign show_regions = is_all_fruits_collection -%}
    {%- if fruit_collection_handles contains collection.handle -%}
      {%- assign show_regions = true -%}
    {%- endif -%}
    {%- if show_regions -%}
      <button type="button" class="qf-pill {% if region_filter_value == 'asia' %}is-active{% endif %}" data-name="jf_region" data-value="asia">{{ 'quick_filters.asia' | t }}</button>
      <button type="button" class="qf-pill {% if region_filter_value == 'america' %}is-active{% endif %}" data-name="jf_region" data-value="america">{{ 'quick_filters.america' | t }}</button>
      <button type="button" class="qf-pill {% if region_filter_value == 'africa' %}is-active{% endif %}" data-name="jf_region" data-value="africa">{{ 'quick_filters.africa' | t }}</button>
      <button type="button" class="qf-pill {% if region_filter_value == 'europe' %}is-active{% endif %}" data-name="jf_region" data-value="europe">{{ 'quick_filters.europe' | t }}</button>
    {%- endif -%}

    {%- comment -%} Clear All Button {%- endcomment -%}
    <button type="button" class="qf-pill clear-all-pill" style="display: none;">
      {{ 'quick_filters.clear_all' | t }} ✕
    </button>
  </div>
  <div
    class="qf-count"
    data-total-count="{{ total_products_count }}"
    data-total-template="{{ 'quick_filters.products_count' | t: count: '__COUNT__' }}"
    data-filtered-template="{{ 'quick_filters.products_count_filtered' | t: count: '__COUNT__', total: '__TOTAL__' }}">
    {% if has_active_collection_filters and unavailable_only_active == false and filtered_products_count < total_products_count %}
      {{ 'quick_filters.products_count_filtered' | t: count: filtered_products_count, total: total_products_count }}
    {% else %}
      {{ 'quick_filters.products_count' | t: count: total_products_count }}
    {% endif %}
  </div>
</div>
        </div>
        <div class="collection-wrapper" id="ProductGrid">
          <div class="cart-loader">
            <div class="loader-spinner"></div>
          </div>
          {%- assign products_per_page = section.settings.number_of_product -%}
          {%- if unavailable_only_active or untreated_only_active or region_filter_value != blank or almost_sold_out_only_active or available_only_active -%}
            {%- assign products_per_page = 250 -%}
          {%- endif -%}
          {% paginate collection.products by products_per_page %}
            {% if collection.products_count > 0 %}
              {% if unavailable_only_active %}
                {%- assign has_unavailable_products = false -%}
                {% for product in collection.products %}
                  {% unless product.available %}
                    {%- assign has_unavailable_products = true -%}
                    {% render 'product-card-primary', product: product, collection: collection %}
                  {% endunless %}
                {% endfor %}

                {% unless has_unavailable_products %}
                  <div class="no-products-found">
                    <h3>{{ 'quick_filters.no_products_found' | t }}</h3>
                    <p>{{ 'quick_filters.no_products_unavailable' | t }}</p>
                    <button type="button" class="reset-link custom-btn black" onclick="window.location.href=window.location.pathname">{{ 'quick_filters.clear_all_filters' | t }}</button>
                  </div>
                {% endunless %}
              {% elsif untreated_only_active or region_filter_value != blank or almost_sold_out_only_active or available_only_active %}
                {%- assign has_custom_filtered_products = false -%}
                {% for product in collection.products %}
                  {%- assign product_quality_label = product.metafields.custom.quality_label.value | default: product.metafields.custom.quality_label | handleize -%}
                  {%- assign matches_custom_filters = true -%}

                  {% if untreated_only_active %}
                    {%- comment -%} "Organic & untreated" pill: keep products that are untreated OR organic-certified. {%- endcomment -%}
                    {%- assign product_is_organic = false -%}
                    {%- for cert in product.metafields.custom.certificate.value -%}
                      {%- if cert.system.handle == 'organic' -%}
                        {%- assign product_is_organic = true -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endfor -%}
                    {%- comment -%} Match untreated across languages (EN untreated / DE unbehandelt / FR non traité). {%- endcomment -%}
                    {%- assign matches_untreated = false -%}
                    {%- if product_quality_label contains 'untreated' or product_quality_label contains 'unbehandelt' or product_quality_label contains 'non-traite' or product_quality_label contains 'nontraite' -%}
                      {%- assign matches_untreated = true -%}
                    {%- endif -%}
                    {% if matches_untreated == false and product_is_organic == false %}
                      {%- assign matches_custom_filters = false -%}
                    {% endif %}
                  {% endif %}

                  {% if region_filter_value != blank %}
                    {%- assign matches_region_filter = false -%}
                    {%- assign product_collection_handles = product.collections | map: 'handle' | join: ',' -%}
                    {%- comment -%} Match region by keyword so translated collection handles work
                        (EN america / FR amerique / DE amerika, etc.). {%- endcomment -%}
                    {% if region_filter_value == 'asia' %}
                      {% if product_collection_handles contains 'asia' or product_collection_handles contains 'asie' or product_collection_handles contains 'asien' %}
                        {%- assign matches_region_filter = true -%}
                      {% endif %}
                    {% elsif region_filter_value == 'europe' %}
                      {% if product_collection_handles contains 'europe' or product_collection_handles contains 'europa' %}
                        {%- assign matches_region_filter = true -%}
                      {% endif %}
                    {% elsif region_filter_value == 'america' %}
                      {% if product_collection_handles contains 'america' or product_collection_handles contains 'amerique' or product_collection_handles contains 'amerika' %}
                        {%- assign matches_region_filter = true -%}
                      {% endif %}
                    {% elsif region_filter_value == 'africa' %}
                      {% if product_collection_handles contains 'africa' or product_collection_handles contains 'afrique' or product_collection_handles contains 'afrika' %}
                        {%- assign matches_region_filter = true -%}
                      {% endif %}
                    {% endif %}

                    {% unless matches_region_filter %}
                      {%- assign matches_custom_filters = false -%}
                    {% endunless %}
                  {% endif %}

                  {%- comment -%} Availability dropdown: "Available Now" / "Almost Sold Out" match on the
                      product's reference variant (same preferred/first-available variant logic used for
                      the card's stock badge), so results match what the card itself shows. {%- endcomment -%}
                  {% if almost_sold_out_only_active or available_only_active %}
                    {%- assign matches_availability = false -%}
                    {%- assign ref_variant = nil -%}
                    {%- for variant in product.variants -%}
                      {%- if variant.metafields.custom.is_prior == true and variant.available -%}
                        {%- assign ref_variant = variant -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endfor -%}
                    {%- if ref_variant == nil -%}
                      {%- for variant in product.variants -%}
                        {%- if variant.available -%}
                          {%- assign ref_variant = variant -%}
                          {%- break -%}
                        {%- endif -%}
                      {%- endfor -%}
                    {%- endif -%}
                    {%- if ref_variant == nil -%}
                      {%- assign ref_variant = product.variants.first -%}
                    {%- endif -%}

                    {%- assign ref_tracked = false -%}
                    {%- if ref_variant.inventory_management != blank -%}
                      {%- assign ref_tracked = true -%}
                    {%- endif -%}

                    {%- assign ref_unavailable = false -%}
                    {%- if ref_variant.available == false -%}
                      {%- assign ref_unavailable = true -%}
                    {%- elsif ref_tracked and ref_variant.inventory_quantity <= 0 -%}
                      {%- assign ref_unavailable = true -%}
                    {%- endif -%}

                    {%- assign ref_almost_sold_out = false -%}
                    {%- if ref_unavailable == false and ref_tracked and ref_variant.inventory_quantity <= 15 -%}
                      {%- assign ref_almost_sold_out = true -%}
                    {%- endif -%}

                    {% if almost_sold_out_only_active and ref_unavailable == false and ref_almost_sold_out %}
                      {%- assign matches_availability = true -%}
                    {% elsif available_only_active and ref_unavailable == false and ref_almost_sold_out == false %}
                      {%- assign matches_availability = true -%}
                    {% endif %}

                    {% unless matches_availability %}
                      {%- assign matches_custom_filters = false -%}
                    {% endunless %}
                  {% endif %}

                  {% if matches_custom_filters and product.available %}
                    {%- assign has_custom_filtered_products = true -%}
                    {% render 'product-card-primary', product: product, collection: collection %}
                  {% endif %}
                {% endfor %}
                {% for product in collection.products %}
                  {%- assign product_quality_label = product.metafields.custom.quality_label.value | default: product.metafields.custom.quality_label | handleize -%}
                  {%- assign matches_custom_filters = true -%}

                  {% if almost_sold_out_only_active or available_only_active %}
                    {%- comment -%} Both options are subsets of in-stock products, so they never match
                        here in the fully-unavailable loop. {%- endcomment -%}
                    {%- assign matches_custom_filters = false -%}
                  {% endif %}

                  {% if untreated_only_active %}
                    {%- comment -%} "Organic & untreated" pill: keep products that are untreated OR organic-certified. {%- endcomment -%}
                    {%- assign product_is_organic = false -%}
                    {%- for cert in product.metafields.custom.certificate.value -%}
                      {%- if cert.system.handle == 'organic' -%}
                        {%- assign product_is_organic = true -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endfor -%}
                    {%- comment -%} Match untreated across languages (EN untreated / DE unbehandelt / FR non traité). {%- endcomment -%}
                    {%- assign matches_untreated = false -%}
                    {%- if product_quality_label contains 'untreated' or product_quality_label contains 'unbehandelt' or product_quality_label contains 'non-traite' or product_quality_label contains 'nontraite' -%}
                      {%- assign matches_untreated = true -%}
                    {%- endif -%}
                    {% if matches_untreated == false and product_is_organic == false %}
                      {%- assign matches_custom_filters = false -%}
                    {% endif %}
                  {% endif %}

                  {% if region_filter_value != blank %}
                    {%- assign matches_region_filter = false -%}
                    {%- assign product_collection_handles = product.collections | map: 'handle' | join: ',' -%}
                    {%- comment -%} Match region by keyword so translated collection handles work
                        (EN america / FR amerique / DE amerika, etc.). {%- endcomment -%}
                    {% if region_filter_value == 'asia' %}
                      {% if product_collection_handles contains 'asia' or product_collection_handles contains 'asie' or product_collection_handles contains 'asien' %}
                        {%- assign matches_region_filter = true -%}
                      {% endif %}
                    {% elsif region_filter_value == 'europe' %}
                      {% if product_collection_handles contains 'europe' or product_collection_handles contains 'europa' %}
                        {%- assign matches_region_filter = true -%}
                      {% endif %}
                    {% elsif region_filter_value == 'america' %}
                      {% if product_collection_handles contains 'america' or product_collection_handles contains 'amerique' or product_collection_handles contains 'amerika' %}
                        {%- assign matches_region_filter = true -%}
                      {% endif %}
                    {% elsif region_filter_value == 'africa' %}
                      {% if product_collection_handles contains 'africa' or product_collection_handles contains 'afrique' or product_collection_handles contains 'afrika' %}
                        {%- assign matches_region_filter = true -%}
                      {% endif %}
                    {% endif %}

                    {% unless matches_region_filter %}
                      {%- assign matches_custom_filters = false -%}
                    {% endunless %}
                  {% endif %}

                  {% if matches_custom_filters and product.available != true %}
                    {%- assign has_custom_filtered_products = true -%}
                    {% render 'product-card-primary', product: product, collection: collection %}
                  {% endif %}
                {% endfor %}

                {% unless has_custom_filtered_products %}
                  <div class="no-products-found">
                    <h3>{{ 'quick_filters.no_products_found' | t }}</h3>
                    <p>{{ 'quick_filters.no_products_quick_filters' | t }}</p>
                    <button type="button" class="reset-link custom-btn black" onclick="window.location.href=window.location.pathname">{{ 'quick_filters.clear_all_filters' | t }}</button>
                  </div>
                {% endunless %}
              {% else %}
                {%- comment -%} Default view: in-stock products only. Out-of-stock items are
                    hidden here and viewable via the "Out of stock" quick filter (jf_unavailable=1). {%- endcomment -%}
                {% for product in collection.products %}
                  {% if product.available %}
                    {% render 'product-card-primary', product: product, collection: collection %}
                  {% endif %}
                {% endfor %}
                {% if paginate.next %}
                  <div class="load-more-wrap">
                    <button
                      type="button"
                      class="load-more-btn custom-btn black"
                      data-next-url="{{ paginate.next.url }}">
                      {{ 'quick_filters.load_more' | t }}
                    </button>
                  </div>
                {% endif %}
              {% endif %}
            {% else %}
              <div class="no-products-found">
                <h3>{{ 'quick_filters.no_products_found' | t }}</h3>
                <p>{{ 'quick_filters.no_products_default' | t }}</p>
                <button type="button" class="reset-link custom-btn black" onclick="window.location.href=window.location.pathname">{{ 'quick_filters.clear_all_filters' | t }}</button>
              </div>
            {% endif %}
          {% endpaginate %}
        </div>
      </div>
    </div>
  </div>
</div>

<section class="collection-seo-footer">
  <div class="container">
    <div class="seo-sec-wrapper">
      <div class="seo-content" id="seoContent">
        {{ collection.metafields.custom.seo_focused_paragraph | metafield_tag }}
      </div>
      <button type="button" class="seo-show-more" id="seoToggleButton">Show More</button>
    </div>
  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", () => {
  
    // Selectors
    const filterForm = document.querySelector(".tc-filter-wrap form");
    const productGrid = document.querySelector("#ProductGrid");
    const collectionBaseUrl = {{ collection.url | json }};
    const filter_sidebar = document.querySelector('.filter-sidebar');
    const filter_button = document.querySelector('.filter-buttton');
    const filter_close = document.querySelector('.filter-close-mob');
    const clearAllBtn = document.querySelector('.clear-all-pill');
    const loader = productGrid.querySelector('.cart-loader');

    if (!filterForm || !productGrid) return;

    // --- 1. AJAX UTILITIES ---
    function updateProductGrid(extraParams = {}, urlOverride = null) {

        if (!productGrid) return;
        // 1. START LOADING
        if (loader) loader.classList.add('active');
        productGrid.style.pointerEvents = 'none'; // Prevent double-clicks while loading

        const formData = new FormData(filterForm);
        const searchParams = new URLSearchParams(formData);
        const currentUrlParams = new URLSearchParams(window.location.search);

        ['jf_unavailable', 'jf_quality_label', 'jf_region'].forEach((key) => {
            const currentValue = currentUrlParams.get(key);
            if (currentValue) {
                searchParams.set(key, currentValue);
            }
        });

        Object.keys(extraParams).forEach((key) => {
            if (extraParams[key]) {
                searchParams.set(key, extraParams[key]);
            } else {
                searchParams.delete(key);
            }
        });

        const constraints = searchParams.getAll('constraint').filter(Boolean);
        searchParams.delete('constraint');

        // --- Add NoIndex logic ---
        // Check if any filters are active (excluding the sort_by parameter)
        let hasFilters = false;
        searchParams.forEach((value, key) => {
            if (key.includes('filter.') || key === 'constraint') {
                hasFilters = true;
            }
        });

        // If filters are active, append the noindex view
        if (hasFilters) {
            searchParams.set('view', 'noindex');
        } else {
            searchParams.delete('view');
        }

        let url;

        if (urlOverride) {
            url = urlOverride;
        } else {
            const constraintPath = constraints.length ? `/${constraints.join('+')}` : '';
            const queryString = searchParams.toString();
            url = `${collectionBaseUrl}${constraintPath}${queryString ? `?${queryString}` : ''}`;
        }

        fetch(url)
            .then(res => res.text())
            .then(data => {
                const parser = new DOMParser();
                const newDoc = parser.parseFromString(data, "text/html");
                const newGrid = newDoc.querySelector("#ProductGrid");
                const newQuickFilters = newDoc.querySelector(".quick-filters");

                if (newGrid) {
                    productGrid.innerHTML = newGrid.innerHTML;
                }
                
                if (newQuickFilters) {
                    // This replaces the whole quick-filters div, 
                    // updating the 'is-disabled' class automatically
                    const oldFilters = document.querySelector(".quick-filters");
                    oldFilters.className = newQuickFilters.className; 
                    oldFilters.innerHTML = newQuickFilters.innerHTML;
                }

                // Re-run UI syncs
                if (typeof lenis !== 'undefined') lenis.resize();
                if (typeof window.bindProductCardAddForms === 'function') {
                    window.bindProductCardAddForms(productGrid);
                }

                window.history.pushState({}, "", url);
                bindPaginationLinks();
                bindLoadMore();

                // Re-bind click events to new pills injected via AJAX
                bindQuickPills();
                toggleClearAllVisibility();
                updateQuickFilterCount();

                // Re-enable pointer events.
                productGrid.style.pointerEvents = 'all';

                // Scroll to top of grid
                const topPos = productGrid.getBoundingClientRect().top + window.pageYOffset - 100;
                window.scrollTo({ top: topPos, behavior: "smooth" });
            })
            .catch(err => {
                if (loader) loader.classList.remove('active');
                productGrid.style.pointerEvents = 'all';
                console.error("Filter error:", err);
            });
    }

    function toggleClearAllVisibility() {
        const clearAllBtn = document.querySelector('.clear-all-pill');
        const filterForm = document.querySelector(".tc-filter-wrap form");
        if (!clearAllBtn || !filterForm) return;

        // 1. Check for checked inputs (excluding sort_by)
        const hasActiveInputs = Array.from(filterForm.querySelectorAll('input:checked'))
            .some(input => input.name !== 'sort_by');

        // 2. Check for pills that have the 'is-active' class
        const hasActivePills = document.querySelectorAll('.qf-pill.is-active').length > 0;

        // 3. Check the URL for filter parameters (as a fallback)
        const hasUrlFilters = window.location.search.includes('filter.')
            || window.location.search.includes('jf_unavailable=1')
            || window.location.search.includes('jf_availability=')
            || window.location.search.includes('jf_quality_label=untreated')
            || window.location.search.includes('jf_region=');

        if (hasActiveInputs || hasActivePills || hasUrlFilters) {
            clearAllBtn.style.display = 'inline-block';
        } else {
            clearAllBtn.style.display = 'none';
        }
    }

    function updateQuickFilterCount() {
        const countEl = document.querySelector('.qf-count');
        if (!countEl) return;

        const totalCount = parseInt(countEl.dataset.totalCount || '0', 10);
        const filteredTemplate = countEl.dataset.filteredTemplate || '__COUNT__ products out of __TOTAL__';
        const totalTemplate = countEl.dataset.totalTemplate || '__COUNT__ products';
        const visibleCount = document.querySelectorAll('#ProductGrid .product-card-primary').length;

        // Show "X out of Y" whenever fewer products are shown than the collection total
        // (out-of-stock hidden by default, an active quick filter, or more pages to load).
        if (visibleCount < totalCount) {
            countEl.textContent = filteredTemplate
                .replace('__COUNT__', visibleCount)
                .replace('__TOTAL__', totalCount);
        } else {
            countEl.textContent = totalTemplate.replace('__COUNT__', totalCount);
        }
    }

    function bindQuickPills() {
        const pills = document.querySelectorAll('.qf-pill:not(.clear-all-pill)');
        const form = document.querySelector(".tc-filter-wrap form");

        function syncPillStates() {
            const urlParams = new URLSearchParams(window.location.search);

            pills.forEach(pill => {
                const name = pill.getAttribute('data-name');
                const value = pill.getAttribute('data-value');
                const input = form.querySelector(`input[name="${name}"][value="${value}"]`);
                
                if (input) {
                    // Toggle Active State
                    pill.classList.toggle('is-active', input.checked);
                    
                    // Toggle Disabled State (matches your sidebar screenshot)
                    if (input.disabled) {
                        pill.classList.add('is-disabled');
                        pill.style.pointerEvents = 'none'; // Stop further clicks
                    } else {
                        pill.classList.remove('is-disabled');
                        pill.style.pointerEvents = 'all';
                    }
                } else {
                    const activeValues = urlParams.getAll(name);
                    pill.classList.toggle('is-active', activeValues.includes(value));
                    pill.classList.remove('is-disabled');
                    pill.style.pointerEvents = 'all';
                }
            });
        }

        pills.forEach(button => {
            button.onclick = function() {
                const name = this.getAttribute('data-name');
                const value = this.getAttribute('data-value');
                const input = form.querySelector(`input[name="${name}"][value="${value}"]`);

                if (input && !input.disabled) {
                    input.checked = !input.checked;
                    updateProductGrid();
                } else {
                    const isActive = this.classList.contains('is-active');
                    const extraParams = {};

                    if (isActive) {
                        extraParams[name] = '';
                    } else {
                        extraParams[name] = value;
                    }

                    updateProductGrid(extraParams);
                }
            };
        });

        const clearBtn = document.querySelector('.clear-all-pill');
              if (clearBtn) {
                  clearBtn.onclick = (e) => {
                      e.preventDefault();
                      // Redirect to the clean collection URL to strip all filters
                      window.location.href = collectionBaseUrl;
                  };
              }

        syncPillStates();
    }

    function bindPaginationLinks() {
      document.querySelectorAll(".pagination a").forEach(link => {
          link.onclick = (e) => {
              e.preventDefault();
              let url = link.getAttribute("href");
              
              // If the URL doesn't have view=noindex but we are on page 2+, 
              // the theme.liquid logic will handle it, but adding it to the URL is cleaner.
              if (!url.includes('view=noindex')) {
                  url += (url.includes('?') ? '&' : '?') + 'view=noindex';
              }
              
              updateProductGrid({}, url);
          };
      });
  }

    function bindLoadMore() {
        const btn = productGrid.querySelector('.load-more-btn');
        if (!btn) return;

        btn.onclick = () => {
            const url = btn.getAttribute('data-next-url');
            if (!url) return;

            btn.disabled = true;
            btn.classList.add('is-loading');

            fetch(url)
                .then(res => res.text())
                .then(data => {
                    const parser = new DOMParser();
                    const newDoc = parser.parseFromString(data, "text/html");
                    const newGrid = newDoc.querySelector("#ProductGrid");
                    if (!newGrid) return;

                    const newCards = newGrid.querySelectorAll('.product-card-primary');
                    const wrap = btn.closest('.load-more-wrap');
                    newCards.forEach(card => wrap.parentNode.insertBefore(card, wrap));

                    const newBtn = newGrid.querySelector('.load-more-btn');
                    if (newBtn) {
                        btn.setAttribute('data-next-url', newBtn.getAttribute('data-next-url'));
                        btn.disabled = false;
                        btn.classList.remove('is-loading');
                    } else {
                        wrap.remove();
                    }

                    window.history.pushState({}, "", url);

                    updateQuickFilterCount();

                    if (typeof lenis !== 'undefined') lenis.resize();
                    if (typeof window.bindProductCardAddForms === 'function') {
                        window.bindProductCardAddForms(productGrid);
                    }
                })
                .catch(err => {
                    btn.disabled = false;
                    btn.classList.remove('is-loading');
                    console.error("Load more error:", err);
                });
        };
    }

    // --- 2. SIDEBAR TOGGLE & OUTSIDE CLICK ---
    filter_button.onclick = (e) => {
        e.stopPropagation();
        filter_sidebar.classList.add('active');
        if (typeof lenis !== 'undefined') lenis.stop();
    };

    filter_close.onclick = () => closeSidebar();

    filter_sidebar.onclick = (e) => {
        if (e.target === filter_sidebar) closeSidebar();
    };

    function closeSidebar() {
        filter_sidebar.classList.remove('active');
        if (typeof lenis !== 'undefined') lenis.start();
    }

    // --- 3. ACCORDION (Bulletproof Version) ---
    document.querySelectorAll(".form-filter-wrap .ff-head").forEach(head => {
        head.addEventListener('click', function(e) {
            // Kill all other scripts trying to touch this click
            e.preventDefault();
            e.stopPropagation(); 
            e.stopImmediatePropagation(); 

            const body = this.nextElementSibling;
            const isActive = this.classList.contains("active");
            
            // 1. Close ALL other headers and bodies
            document.querySelectorAll(".ff-head").forEach(otherHead => {
                if (otherHead !== this) {
                    otherHead.classList.remove("active");
                    if (otherHead.nextElementSibling) {
                        otherHead.nextElementSibling.style.display = "none";
                    }
                }
            });

            // 2. Toggle the current one
            if (isActive) {
                this.classList.remove("active");
                if (body) body.style.display = "none";
            } else {
                this.classList.add("active");
                if (body) body.style.display = "block";
            }
        });
    });

    // --- 4. OUTSIDE CLICK (Updated to avoid conflicts) ---
    document.addEventListener("click", function(event) {
        // If the click is NOT inside a filter wrap, close everything
        if (!event.target.closest(".form-filter-wrap")) {
            document.querySelectorAll(".ff-in").forEach(el => {
                el.style.display = "none";
            });
            document.querySelectorAll(".ff-head").forEach(el => {
                el.classList.remove("active");
            });
        }
    });

    // Initial Bindings
    filterForm.onsubmit = (e) => {
        e.preventDefault();
        updateProductGrid();
        closeSidebar();
    };

    bindQuickPills();
    bindPaginationLinks();
    bindLoadMore();
    toggleClearAllVisibility();
    updateQuickFilterCount();
});
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const content = document.getElementById('seoContent');
  const button = document.getElementById('seoToggleButton');

  if (content && button) {
    // Hide button if content is already short
    if (content.scrollHeight <= content.offsetHeight) {
      button.style.display = 'none';
    }

    button.addEventListener('click', function() {
      const isExpanded = content.classList.toggle('is-expanded');
      button.textContent = isExpanded ? 'Show Less' : 'Show More';

      // 1. Fix Lenis Scroll
      if (window.lenis) {
        window.lenis.resize();
      }

      // 2. Fix GSAP ScrollTrigger (since it's in your theme)
      if (window.ScrollTrigger) {
        window.ScrollTrigger.refresh();
      }
      
      // Optional: Smoothly scroll to the top of the section when closing
      if (!isExpanded) {
        content.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    });
  }
});
</script>



<script>
   $(document).ready(function() {
      // Toggle logic
      $(".form-filter-wrap.list .ff-head").click(function(e) {
        e.stopPropagation(); 
        
        let $currentBody = $(this).siblings(".ff-in");
        let $currentHead = $(this);
        let $currentParent = $(this).parent(".form-filter-wrap.list");

        // If this one is already open, slide it up
        if ($currentHead.hasClass("active")) {
          $currentBody.slideUp(300).removeClass("active");
          $currentHead.removeClass("active");
          $currentParent.removeClass("active");
        } else {
          // Close any other open filters with a slideUp
          $(".list .ff-in").slideUp(300).removeClass("active");
          $(".list .ff-head").removeClass("active");
          $(".form-filter-wrap.list").removeClass("active");

          // Slide down the clicked one
          $currentBody.slideDown(300).addClass("active");
          $currentHead.addClass("active");
          $currentParent.addClass("active");
        }
      });

      // Close when clicking outside
      $(document).on("click", function(event) {
        if (!$(event.target).closest(".form-filter-wrap.list").length) {
          $(".list .ff-in").slideUp(300).removeClass("active");
          $(".list .ff-head").removeClass("active");
          $(".form-filter-wrap.list").removeClass("active");
        }
      });
    });

</script>

<script>
    document.addEventListener("DOMContentLoaded", () => {
      const filter_button = document.querySelector('.filter-buttton');
      const filter_sidebar = document.querySelector('.filter-sidebar');
      const filter_close = document.querySelector('.filter-close-mob');

      // Open sidebar
      filter_button.addEventListener('click', function(e) {
          e.stopPropagation(); 
          filter_sidebar.classList.add('active');
          if (typeof lenis !== 'undefined') lenis.stop(); // Stop Lenis scrolling
      });

      // Close sidebar via close button
      filter_close.addEventListener('click', function() {
          filter_sidebar.classList.remove('active');
          if (typeof lenis !== 'undefined') lenis.start(); // Restart Lenis
      });

      // Close sidebar when clicking the BACKGROUND
      filter_sidebar.addEventListener('click', function(event) {
          // 'event.target' is the element you actually clicked
          // 'this' is the filter_sidebar itself
          // If they match, it means you clicked the background overlay, not the content inside
          if (event.target === this) {
              filter_sidebar.classList.remove('active');
              if (typeof lenis !== 'undefined') lenis.start();
          }
      });

      // Optional: Keep the document click as a fallback for the button area
      document.addEventListener('click', function(event) {
          const isClickOnButton = filter_button.contains(event.target);
          
          // If clicking somewhere else entirely that isn't the sidebar or button
          if (!filter_sidebar.contains(event.target) && !isClickOnButton) {
              filter_sidebar.classList.remove('active');
              if (typeof lenis !== 'undefined') lenis.start();
          }
      });
  });
</script>

