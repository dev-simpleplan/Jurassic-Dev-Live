{% comment %}
  FAQs are pulled from the collection metafield custom.collection_faq (list of
  "FAQ item" metaobjects), mirroring how the product page uses custom.faqs.
  Field keys are read with fallbacks so either naming works
  (question/answer/faq_image or faq_label/faq_data/faq_image).
  If the collection has no metafield set, the section's own blocks are used.
{% endcomment %}
{% assign faq_meta_items = collection.metafields.custom.collection_faq.value %}

<div class="faq-sec">
    <div class="container-fluid">
        <div class="heading with-link">
            <h2>{{ section.settings.heading }}</h2>
            {% if section.settings.cta_url %}
                <div class="heading-link hide-mobile">
                    <a href="{{ section.settings.cta_url }}">{{ section.settings.cta_text }}</a>
                </div>
            {% endif %}
        </div>
        <div class="faq-wrap">
            <div class="faq-accordian-wrapper">
                {% if faq_meta_items != blank %}
                    {% for item in faq_meta_items %}
                        {% assign faq_q = item.question | default: item.faq_label %}
                        {% assign faq_a = item.answer | default: item.faq_data %}
                        {% assign faq_img = item.faq_image | default: item.image %}
                        <div class="faq-item" data-image="{{ faq_img | img_url: 'master' }}">
                            <div class="faq-question">
                                <div class="faq-question-left">
                                    <div class="f-question">
                                      <h3>{{ faq_q }}</h3>
                                    </div>
                                </div>
                                <div class="faq-question-right">
                                    {% render 'plus' %}
                                </div>
                            </div>
                            <div class="faq-answer">
                                <div class="f-answer">
                                    {{ faq_a | metafield_tag }}
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                {% else %}
                    {% for block in section.blocks %}
                        <div class="faq-item" {{ block.shopify_attributes }} data-image="{{ block.settings.faq_image | img_url: 'master' }}">
                            <div class="faq-question">
                                <div class="faq-question-left">
                                    <div class="f-question">
                                      <h3>{{ block.settings.question }}</h3>
                                    </div>
                                </div>
                                <div class="faq-question-right">
                                    {% render 'plus' %}
                                </div>
                            </div>
                            <div class="faq-answer">
                                <div class="f-answer">
                                    {{ block.settings.answer }}
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
            <div class="faq-image">
                {% comment %} Initial image: first metafield item, else first block, else fallback {% endcomment %}
                {% if faq_meta_items != blank %}
                    {% assign first_faq_image = faq_meta_items.first.faq_image | default: faq_meta_items.first.image %}
                {% else %}
                    {% assign first_faq_image = section.blocks.first.settings.faq_image %}
                {% endif %}
                <img id="faq-dynamic-image" width="100%" height="100%"
                     src="{{ first_faq_image | default: section.settings.fallback_image | img_url:'master' }}"
                     alt="{{ first_faq_image.alt }}">
            </div>
        </div>

        {% if section.settings.cta_url %}
            <div class="heading-link show-mobile">
                <a href="{{ section.settings.cta_url }}">{{ section.settings.cta_text }}</a>
            </div>
        {% endif %}
    </div>
</div>

<script>
$(document).ready(function () {
    var $mainImage = $('#faq-dynamic-image');

    // 1. Initialize: Set image to the first item's image on load
    var firstImage = $('.faq-item').first().data('image');
    if(firstImage) {
        $mainImage.attr('src', firstImage);
    }

    var $firstItem = $('.faq-item').first();
    $firstItem.addClass('active');
    $firstItem.find('.faq-answer').show();

    $('.faq-question').click(function () {
        var $faqItem = $(this).parent('.faq-item');
        var $faqAnswer = $faqItem.find('.faq-answer');
        var newImageUrl = $faqItem.data('image'); // Get image URL from data attribute

        if ($faqItem.hasClass('active')) {
            $faqItem.removeClass('active');
            $faqAnswer.slideUp();
        } else {
            $('.faq-item').removeClass('active');
            $('.faq-answer').slideUp();
            
            $faqItem.addClass('active');
            $faqAnswer.slideDown();

            // 2. Change the image with a simple fade effect
            if(newImageUrl) {
                $mainImage.fadeOut(200, function() {
                    $(this).attr('src', newImageUrl).fadeIn(200);
                });
            }
        }
    });
});
</script>

{% schema %}
  {
    "name": "FAQ Page Section",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Frequently Asked Questions"
      },
      {
        "type": "url",
        "id": "cta_url",
        "label": "CTA URL (right side link)"
      },
      {
        "type": "text",
        "id": "cta_text",
        "label": "CTA text",
        "default": "All FAQs"
      },
      {
        "type": "image_picker",
        "id": "fallback_image",
        "label": "Fallback Image (If block has no image)"
      }
    ],
    "blocks": [
      {
        "type": "faq",
        "name": "FAQ Item",
        "settings": [
          {
            "type": "text",
            "id": "question",
            "label": "Question",
            "default": "How do I track my order?"
          },
          {
            "type": "richtext",
            "id": "answer",
            "label": "Answer",
            "default": "<p>You can track your order using the link provided in your shipping confirmation email.</p>"
          },
          {
            "type": "image_picker",
            "id": "faq_image",
            "label": "Associated Image"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "FAQ Page Section",
        "blocks": [
          { "type": "faq" },
          { "type": "faq" }
        ]
      }
    ]
  }
{% endschema %} 

