<section class="newsletter">
    <div class="newsletter-top">
        <div class="nlt-image-wrap">
            <div class="nlt-left">
                <img src="{{ section.settings.left-image | img_url: 'master' }}" alt="Logo">
            </div>
            <div class="nlt-right">
                <img src="{{ section.settings.right-image | img_url: 'master' }}" alt="Logo">
            </div>
        </div>
    </div>

    <div class="newsletter-bottom">
        <div class="container">
            <div class="nl-in">
                <div class="nli-headings">
                    <div class="heading center">
                        <h2 data-aos="fade-up" data-aos-duration="1000">
                            {{ section.settings.heading }}
                        </h2>
                        <p data-aos="fade-up" data-aos-duration="1000" data-aos-delay="50">
                            {{ section.settings.text }}
                        </p>
                    </div>
                </div>

                <div class="nl-form">
                    {% form 'customer' %}

                        <!-- Redirect to the thankyou page after a successful signup -->
                        <input type="hidden" name="return_to" value="{{ pages['thankyou'].url }}">

                        <!-- Newsletter Tag -->
                        <input type="hidden" name="contact[tags]" value="newsletter">

                        <div class="form-in">
                            <div class="email_input">
                                <input
                                    type="email"
                                    name="contact[email]"
                                    placeholder="{{ 'sections.newsletter.email_placeholder' | t }}"
                                    required>
                            </div>

                            <div class="submit_btn">
                                <input
                                    type="submit"
                                    class="custom-btn black"
                                    value="{{ 'sections.newsletter.subscribe' | t }}">
                            </div>
                        </div>

                        {% if form.posted_successfully? %}
                            {% comment %} return_to redirects server-side; this JS is a
                               fallback, and the message shows if thankyou is unavailable
                               in this market (blank URL). {% endcomment %}
                            {% if pages['thankyou'].url != blank %}
                                <script>
                                    window.location.href = {{ pages['thankyou'].url | json }};
                                </script>
                            {% endif %}
                            <div class="newsletter-success">
                                <p>{{ 'sections.newsletter.success' | t }}</p>
                            </div>
                        {% endif %}

                        {% if form.errors %}
                            <div class="newsletter-error">
                                {{ form.errors | default_errors }}
                            </div>
                        {% endif %}

                    {% endform %}

                </div>
            </div>
        </div>
    </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "image_picker",
      "id": "left-image",
      "label": "Left Image"
    },
    {
      "type": "image_picker",
      "id": "right-image",
      "label": "Right Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text"
    }
  ]
}
{% endschema %}