{{ 'okendo-dedicated-reviews.js' | asset_url | script_tag }}
{{ 'okendo-dedicated-reviews.css' | asset_url | stylesheet_tag: preload: true }}

<div class="container container-reviews">
    <h2 class="heading center">{{ page.title }}</h2>
        <div class="reviews-intro center">
            {% if section.settings.intro_text != blank %}
                <p class="reviews-intro__text center">
                    {{ section.settings.intro_text }}
                </p>
            {% endif %}

            {% if section.settings.button_label != blank and section.settings.button_link != blank %}
                <a href="{{ section.settings.button_link }}" class="custom-btn black reviews-intro__button center">
                    {{ section.settings.button_label }}
                </a>
            {% endif %}
        </div>
    <div class="orc-allReviewsCollections">
        <div id="orc-collection-control" style="display: none">
            <div id="orc-collection-controls-label" class="orc-collectionControlsLabel">Select a product range</div>
            <div class="orc-collectionControls" role="radiogroup" aria-labelledby="orc-collection-controls-label">
                <div class="orc-collectionControls-item custom-btn black">
                    <input
                        id="orc-reviews-control-3"
                        class="orc-collectionControls-item-input orc-collectionControls-item-input--checked js-orc-collectionRadio"
